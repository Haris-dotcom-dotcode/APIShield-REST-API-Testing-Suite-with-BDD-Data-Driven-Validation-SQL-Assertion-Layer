    "mysql2": "^3.6.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.3.0",
    "chai": "^4.3.10",
    "newman": "^6.1.0",
    "newman-reporter-htmlextra": "^1.23.0"
  }
}